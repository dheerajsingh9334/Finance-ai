DATABASE_URL="postgresql://user:password@localhost:5432/finance_db"
ACCESS_TOKEN_SECRET="your-super-secret-key-minimum-32-characters-long"
REFRESH_TOKEN_SECRET="another-super-secret-key-minimum-32-characters-long"
PORT=5000
NODE_ENV="development"
REDIS_URL="redis://localhost:6379"
GEMINI_API_KEY="your-gemini-api-key"
